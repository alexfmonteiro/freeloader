#!/usr/bin/env -S uv run --script
# /// script
# dependencies = ["requests"]
# ///
"""
freeloader — offload file/web/log parsing to free cloud LLMs (Gemini/Groq) instead of burning
Claude tokens on content you only need to extract or summarize.

Usage:
  freeloader '<instructions>' [<file_path_or_->]
  echo "data" | freeloader '<instructions>'
  curl -s https://example.com | freeloader '<instructions>'
  freeloader --list-providers
  freeloader --stats
  freeloader --discover
"""

import sys
import json
import argparse
import os
import re
import time
import requests
from datetime import datetime, timezone, timedelta
from pathlib import Path
from collections import Counter

# ── Paths ──────────────────────────────────────────────────────────────────────
CONFIG_PATH = os.path.expanduser("~/.config/freeloader/config.json")
LEGACY_CONFIG_PATH = os.path.expanduser("~/.claude/local-parse-config.json")
TEE_DIR = Path.home() / ".local" / "share" / "freeloader" / "tee"
STATS_FILE = Path.home() / ".local" / "share" / "freeloader" / "stats.json"
CLAUDE_PROJECTS_DIR = Path.home() / ".claude" / "projects"

# ── Limits ─────────────────────────────────────────────────────────────────────
DEFAULT_TIMEOUT = 300
RETRYABLE_STATUSES = {429, 500, 502, 503, 504}
MAX_RETRIES = 3
DEFAULT_MAX_TOKENS = 4000  # caps LLM response; overridable per provider in config
# Rough char-to-token ratio (~4 chars/token). Leave room for instructions + response.
MAX_CONTENT_CHARS = {
    "gemini": 3_500_000,  # Gemini 2.5 Flash: ~1M tokens
    "groq": 400_000,      # Groq Llama 4 Scout: ~100K tokens effective
}
DEFAULT_MAX_CHARS = 200_000
TEE_MAX_FILES = 20
CHARS_PER_TOKEN = 4  # rough estimate for savings tracking

# ── Bad-distillation detection ──────────────────────────────────────────────────
# If the LLM response contains these phrases, it failed to process the input usefully.
BAD_DISTILLATION_PHRASES = [
    "please provide",
    "i cannot",
    "i don't have",
    "i do not have",
    "insufficient information",
    "unable to",
    "no content provided",
    "no information provided",
    "i need more",
    "could you please",
    "as an ai",
    "i'm unable",
    "i am unable",
    "without more context",
    "cannot determine",
    "not enough information",
]

# ── Interactive passthrough detection ──────────────────────────────────────────
# If input ends with these patterns, pass through raw — don't send to an LLM.
INTERACTIVE_TAIL_PATTERNS = [
    r"\[Y/n\]\s*$",
    r"\[y/N\]\s*$",
    r"\[Y/N\]\s*$",
    r"[Pp]assword:\s*$",
    r"[Ee]nter passphrase",
    r"\(yes/no\)\s*$",
    r"Press any key",
    r"Continue\? ",
    r"Are you sure",
]

# ── System prompt ──────────────────────────────────────────────────────────────
# Framed for the actual consumer: a paid AI coding assistant, not a human.
# This nudges the free LLM toward machine-readable brevity.
SYSTEM_PROMPT_TEMPLATE = (
    "You are a precise extraction and summarization tool. "
    "Your output is consumed DIRECTLY by a paid AI assistant (Claude) as part of its context "
    "window — not by a human. Rules:\n"
    "- Be maximally concise. Every output token costs money.\n"
    "- Output ONLY what was asked for. No preamble, no explanation, no 'here is the result'.\n"
    "- Plain text preferred. Use minimal markdown only if it genuinely aids structure (tables, lists).\n"
    "- If extracting data, use the most compact representation that preserves meaning.\n"
    "- If nothing relevant exists in the input, output exactly: [nothing found]\n"
    "- If you cannot fit all results within your token limit, include as many as possible "
    "then end with: [truncated — N more items not shown]\n"
    "- Never apologize, explain limitations, or ask for clarification.\n\n"
    "Task: {instructions}"
)

OPUS_COST_PER_M = 15.0  # $/M input tokens at Opus pricing


# ── Config ─────────────────────────────────────────────────────────────────────

def load_config():
    path = CONFIG_PATH if os.path.exists(CONFIG_PATH) else LEGACY_CONFIG_PATH
    try:
        with open(path, "r") as f:
            return json.load(f)
    except FileNotFoundError:
        print(f"Error: config not found. Run install.sh or create {CONFIG_PATH}", file=sys.stderr)
        sys.exit(1)


def list_providers():
    config = load_config()
    for p in config["providers"]:
        key_status = "configured" if p["api_key"] and not p["api_key"].startswith("YOUR_") else "NOT SET"
        max_tok = p.get("max_tokens", DEFAULT_MAX_TOKENS)
        print(f"  {p['name']:10s}  model={p['model']}  max_tokens={max_tok}  key={key_status}")


# ── Content helpers ────────────────────────────────────────────────────────────

def truncate_content(content, provider_name):
    limit = MAX_CONTENT_CHARS.get(provider_name, DEFAULT_MAX_CHARS)
    if len(content) <= limit:
        return content, False
    return content[:limit], True


def is_bad_distillation(result: str, content: str) -> bool:
    """Return True if the LLM response looks useless — trigger fallback to next provider."""
    result_lower = result.lower().strip()
    for phrase in BAD_DISTILLATION_PHRASES:
        if phrase in result_lower:
            return True
    # Suspiciously tiny response for non-trivial input
    if len(content) > 1000 and len(result.strip()) < 15:
        return True
    return False


def is_interactive_input(content: str) -> bool:
    """Return True if input ends with an interactive prompt — pass through without LLM."""
    tail = content[-500:]
    for pattern in INTERACTIVE_TAIL_PATTERNS:
        if re.search(pattern, tail, re.IGNORECASE | re.MULTILINE):
            return True
    return False


def read_content(source):
    if source is None or source == "-":
        return sys.stdin.read()
    try:
        with open(source, "r", encoding="utf-8", errors="replace") as f:
            return f.read()
    except (FileNotFoundError, IsADirectoryError, PermissionError):
        return source


# ── Tee (raw output recovery) ──────────────────────────────────────────────────

def save_tee(content: str) -> Path:
    """Save raw content to tee dir so it can be retrieved after provider failure."""
    TEE_DIR.mkdir(parents=True, exist_ok=True)
    ts = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    tee_file = TEE_DIR / f"freeloader-{ts}.txt"
    tee_file.write_text(content, encoding="utf-8")
    # Rotate: keep only the last TEE_MAX_FILES files
    files = sorted(TEE_DIR.glob("freeloader-*.txt"))
    for old in files[:-TEE_MAX_FILES]:
        old.unlink(missing_ok=True)
    return tee_file


# ── Stats tracking ─────────────────────────────────────────────────────────────

def track_stats(input_chars: int, output_chars: int, provider: str):
    """Append a stats entry. Best-effort — never blocks execution."""
    try:
        STATS_FILE.parent.mkdir(parents=True, exist_ok=True)
        stats = []
        if STATS_FILE.exists():
            try:
                stats = json.loads(STATS_FILE.read_text())
            except (json.JSONDecodeError, OSError):
                stats = []
        entry = {
            "ts": datetime.now(timezone.utc).isoformat(),
            "provider": provider,
            "input_chars": input_chars,
            "output_chars": output_chars,
            "tokens_consumed": input_chars // CHARS_PER_TOKEN,
            "tokens_saved": max(0, (input_chars - output_chars) // CHARS_PER_TOKEN),
        }
        stats.append(entry)
        if len(stats) > 1000:
            stats = stats[-1000:]
        STATS_FILE.write_text(json.dumps(stats, indent=2))
    except OSError:
        pass


def show_stats():
    if not STATS_FILE.exists():
        print("No stats yet. Run some freeloader tasks first.")
        return
    try:
        stats = json.loads(STATS_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        print("Stats file unreadable.")
        return
    if not stats:
        print("No stats recorded yet.")
        return

    total_saved = sum(e.get("tokens_saved", 0) for e in stats)
    total_consumed = sum(e.get("tokens_consumed", 0) for e in stats)
    total_calls = len(stats)
    provider_counts = Counter(e.get("provider", "?") for e in stats)
    cutoff = (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()
    recent = [e for e in stats if e.get("ts", "") >= cutoff]
    recent_saved = sum(e.get("tokens_saved", 0) for e in recent)
    total_cost_saved = total_saved / 1_000_000 * OPUS_COST_PER_M

    print("freeloader stats")
    print("────────────────")
    print(f"Total calls:        {total_calls:,}")
    print(f"Tokens routed out:  {total_consumed:,}")
    print(f"Tokens saved:       {total_saved:,}  (~${total_cost_saved:.2f} at Opus pricing)")
    print(f"Last 30 days saved: {recent_saved:,} tokens")
    print()
    print("By provider:")
    for prov, count in provider_counts.most_common():
        print(f"  {prov:12s}  {count:,} calls")


# ── Discover missed savings ────────────────────────────────────────────────────

def _find_tool_uses(obj, results=None):
    """Recursively find all tool_use blocks in a JSON object."""
    if results is None:
        results = []
    if isinstance(obj, dict):
        if obj.get("type") == "tool_use":
            results.append(obj)
        for v in obj.values():
            _find_tool_uses(v, results)
    elif isinstance(obj, list):
        for item in obj:
            _find_tool_uses(item, results)
    return results


def discover_missed_savings():
    """Scan Claude Code session JSONL logs for Read/WebFetch/Grep calls that bypassed freeloader."""
    if not CLAUDE_PROJECTS_DIR.exists():
        print("No Claude Code session data found at ~/.claude/projects/")
        return

    jsonl_files = list(CLAUDE_PROJECTS_DIR.rglob("*.jsonl"))
    if not jsonl_files:
        print("No session logs found.")
        return

    missed_reads = []
    missed_fetches = []
    missed_greps = []

    for jf in jsonl_files:
        try:
            with open(jf, "r", encoding="utf-8", errors="replace") as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        obj = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    for tool in _find_tool_uses(obj):
                        name = tool.get("name", "")
                        inp = tool.get("input", {})
                        if name == "Read":
                            fp = inp.get("file_path", "")
                            if fp:
                                try:
                                    size = os.path.getsize(fp)
                                    if size > 10_000:
                                        missed_reads.append({"path": fp, "size": size})
                                except OSError:
                                    pass
                        elif name == "WebFetch":
                            url = inp.get("url", "")
                            if url:
                                missed_fetches.append({"url": url})
                        elif name == "Grep":
                            pattern = inp.get("pattern", "")
                            if pattern:
                                missed_greps.append({"pattern": pattern, "path": inp.get("path", "")})
        except OSError:
            continue

    total_ops = len(missed_reads) + len(missed_fetches) + len(missed_greps)
    if total_ops == 0:
        print("No missed savings found in session history.")
        return

    # Rough token estimates: read=file_size/4, fetch=10K tokens avg, grep=2K tokens avg
    est_tokens = (
        sum(r["size"] // CHARS_PER_TOKEN for r in missed_reads)
        + len(missed_fetches) * 10_000
        + len(missed_greps) * 2_000
    )
    # Freeloader would compress to ~5% of original
    est_saved = int(est_tokens * 0.90)
    est_cost = est_saved / 1_000_000 * OPUS_COST_PER_M

    print("Missed savings in Claude Code session history")
    print("─────────────────────────────────────────────")
    print(f"Large file reads (>10KB) bypassing freeloader: {len(missed_reads)}")
    print(f"WebFetch calls bypassing freeloader:           {len(missed_fetches)}")
    print(f"Grep calls that could use freeloader:          {len(missed_greps)}")
    print()
    print(f"Estimated tokens that could have been saved:  ~{est_saved:,}")
    print(f"Estimated cost saved (at Opus pricing):       ~${est_cost:.2f}")
    print()
    if missed_reads:
        print(f"Largest files read directly (top 5):")
        for item in sorted(missed_reads, key=lambda x: x["size"], reverse=True)[:5]:
            print(f"  {item['size'] // 1024:>6}KB  {item['path']}")
    if missed_fetches:
        print(f"WebFetch URLs (up to 5):")
        for item in missed_fetches[:5]:
            print(f"  {item['url']}")


# ── LLM calls ─────────────────────────────────────────────────────────────────

def call_llm(provider, instructions, content):
    content, was_truncated = truncate_content(content, provider["name"])
    if was_truncated:
        instructions += "\n\nNOTE: The input was truncated to fit context limits. Work with what is provided."
        print(f"[{provider['name']}] input truncated to {len(content):,} chars", file=sys.stderr)

    max_tokens = provider.get("max_tokens", DEFAULT_MAX_TOKENS)
    system_prompt = SYSTEM_PROMPT_TEMPLATE.format(instructions=instructions)

    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {provider['api_key']}",
    }
    payload = {
        "model": provider["model"],
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": content},
        ],
        "temperature": 0.1,
        "max_tokens": max_tokens,
        "stream": False,
    }
    r = requests.post(
        f"{provider['base_url']}/chat/completions",
        headers=headers,
        json=payload,
        timeout=DEFAULT_TIMEOUT,
    )
    r.raise_for_status()
    return r.json()["choices"][0]["message"]["content"]


def call_with_retry(provider, instructions, content):
    last_error = None
    for attempt in range(MAX_RETRIES):
        try:
            return call_llm(provider, instructions, content)
        except requests.exceptions.HTTPError as e:
            status = e.response.status_code if e.response is not None else 0
            if status in RETRYABLE_STATUSES and attempt < MAX_RETRIES - 1:
                wait = 2 ** attempt
                print(f"[{provider['name']}] {status}, retrying in {wait}s... ({attempt + 1}/{MAX_RETRIES})", file=sys.stderr)
                time.sleep(wait)
                last_error = e
            else:
                raise
    raise last_error


def call_with_fallback(providers, instructions, content):
    errors = []
    for p in providers:
        if not p["api_key"] or p["api_key"].startswith("YOUR_"):
            errors.append((p["name"], "API key not configured"))
            continue
        print(f"[freeloader] querying {p['name']}...", file=sys.stderr)
        try:
            result = call_with_retry(p, instructions, content)
            # Bad-distillation guard: if response looks useless, try next provider
            if is_bad_distillation(result, content):
                print(f"[{p['name']}] response looks unhelpful, trying next provider...", file=sys.stderr)
                errors.append((p["name"], "bad distillation"))
                continue
            return result, p["name"]
        except requests.exceptions.HTTPError as e:
            status = e.response.status_code if e.response is not None else "?"
            errors.append((p["name"], f"HTTP {status}"))
            print(f"[{p['name']}] failed ({status}), trying next provider...", file=sys.stderr)
        except requests.exceptions.Timeout:
            errors.append((p["name"], "timeout"))
            print(f"[{p['name']}] timed out, trying next provider...", file=sys.stderr)
        except requests.exceptions.RequestException as e:
            errors.append((p["name"], str(e)))
            print(f"[{p['name']}] error, trying next provider...", file=sys.stderr)

    # All providers failed — save raw content to tee for recovery
    tee_path = save_tee(content)
    print("All providers failed:", file=sys.stderr)
    for name, err in errors:
        print(f"  {name}: {err}", file=sys.stderr)
    print(f"[freeloader] raw input saved to: {tee_path}", file=sys.stderr)
    print(f"[freeloader] recover with: cat {tee_path}", file=sys.stderr)
    sys.exit(1)


# ── Main ───────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Offload parsing/summarization to free cloud LLMs instead of burning Claude tokens.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument("--list-providers", action="store_true", help="List configured providers and exit")
    parser.add_argument("--stats", action="store_true", help="Show token savings statistics")
    parser.add_argument("--discover", action="store_true", help="Scan Claude Code session history for missed savings")
    parser.add_argument("instructions", nargs="?", help="What to extract or summarize")
    parser.add_argument(
        "source",
        nargs="?",
        default=None,
        help="File path, raw text, or '-' for stdin (omit to read from stdin)",
    )

    args = parser.parse_args()

    if args.list_providers:
        list_providers()
        return

    if args.stats:
        show_stats()
        return

    if args.discover:
        discover_missed_savings()
        return

    if not args.instructions:
        parser.error("instructions are required (pass as first positional argument)")

    content = read_content(args.source)

    if not content.strip():
        print("Error: empty input", file=sys.stderr)
        sys.exit(1)

    # Interactive passthrough — don't LLM-process prompts expecting user input
    if is_interactive_input(content):
        print(content, end="")
        return

    config = load_config()
    result, provider_used = call_with_fallback(config["providers"], args.instructions, content)

    track_stats(len(content), len(result), provider_used)
    print(f"[via {provider_used}]", file=sys.stderr)
    print(result)


if __name__ == "__main__":
    main()
